// 1. Проверка объявления функции
func factorial(n: int) -> int {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

// 2. Проверка переменных и вызова функции
var num: int = 5;
var result: int = factorial(num);

// 3. Проверка цикла while и присваивания
var counter: int = 10;
while (counter > 0) {
    counter = counter - 1;
}

// 4. Проверка цикла for
for (var i: int = 0; i < 5; i = i + 1) {
    var temp: int = i * 2;
}

// 5. Проверка логических операций и if-else
if (result >= 100 and counter == 0) {
    var success: bool = true;
} else {
    var success: bool = false;
}


// 1. Определение класса
class Hero {
    var hp: int;
    var power: int;

    func takeDamage(damage: int) -> int {
        this.hp = this.hp - damage;
        return this.hp;
    }
}

// 2. Использование класса
var warrior: Hero = Hero();
warrior.hp = 100;
warrior.power = 50;

// 3. Вызов метода
var remainingHp: int = warrior.takeDamage(20);

// 4. Обычная логика (для проверки совместимости)
if (remainingHp < 50) {
    var status: str = "Warning: Low HP";
}